# ===========================================
# TeemUp Root .gitignore
# ===========================================

# Environment files (contain secrets)
.env
.env.local
.env.*.local
!.env.example

# Claude Code
.claude/

# IDE
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
~$*

# Logs
*.log
logs/

# Python (face-verification)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Documentation (local only)
docs/

# Docker volumes (local development)
postgres_data/
redis_data/
